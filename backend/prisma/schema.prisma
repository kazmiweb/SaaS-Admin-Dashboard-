generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RESELLER
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLACKLISTED
  INACTIVE
}

enum ApiHttpMethod {
  GET
  POST
}

enum ApiAuthType {
  NONE
  API_KEY_HEADER
  BEARER_TOKEN
  BASIC_AUTH
  SESSION_LOGIN
  OAUTH2
}

enum QueryType {
  CNIC
  PHONE
  ENGINE
  CHASSIS
  REGISTRATION
  LICENSE
  CUSTOM
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportMessageSender {
  USER
  ADMIN
  SYSTEM
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)

  // Single-device enforcement (USER/RESELLER)
  deviceId      String?
  deviceBoundAt DateTime?

  credits              Int       @default(0)
  expireAt             DateTime?
  acceptedDisclaimerAt DateTime?
  theme                String    @default("light")
  twoFactorEnabled     Boolean   @default(false)
  profileImageData     String?
  billingType          String    @default("PAID") // PAID|FREE|DEMO
  revenueExcluded      Boolean   @default(false)
  monthlyPackageCoins  Int       @default(0)

  resellerId   String?
  reseller     User?   @relation("ResellerUsers", fields: [resellerId], references: [id])
  createdUsers User[]  @relation("ResellerUsers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens        RefreshToken[]
  apiKeys              ApiKey[]
  creditLogs           CreditLog[]
  searchHistory        SearchHistory[]
  accessLogs           AccessLog[]
  userServiceOverrides UserServiceAccess[]
  transactions         Transaction[]
  adminAudits          AdminAudit[]        @relation("AdminAuditActor")
  creditLogsAsActor    CreditLog[]         @relation("CreditLogActor")
  notifications        Notification[]
  supportTickets       SupportTicket[]     @relation("SupportTicketOwner")
  assignedTickets      SupportTicket[]     @relation("SupportTicketAssignee")
  supportMessages      SupportMessage[]    @relation("SupportMessageAuthor")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  name       String
  jti        String    @unique
  scopes     String    @default("search:read")
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([userId, createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model OTPVerification {
  id        String    @id @default(cuid())
  email     String
  codeHash  String
  purpose   String // SIGNUP or CHANGE_EMAIL
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, purpose])
}

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String? // e.g. "fa-magnifying-glass"
  type        String   @default("Search") // Search|Upload|Analysis
  status      Boolean  @default(true)
  defaultCost Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  serviceApis         ServiceApi[]
  userServiceAccesses UserServiceAccess[]
  searchHistory       SearchHistory[]
}

model ApiConfig {
  id           String        @id @default(cuid())
  name         String
  method       ApiHttpMethod
  baseUrl      String
  endpoint     String
  queryParam   String
  description  String?
  authType     ApiAuthType   @default(NONE)
  apiKeyHeader String?
  apiKeyValue  String?
  bearerToken  String?
  basicUser    String?
  basicPass    String?

  // session login (scaffold fields)
  loginUrl       String?
  usernameField  String?
  passwordField  String?
  captchaEnabled Boolean @default(false)
  sessionPolicy  String? // Auto-refresh|Manual

  // query types support
  supportsCnic    Boolean @default(false)
  supportsPhone   Boolean @default(false)
  supportsEngine  Boolean @default(false)
  supportsChassis Boolean @default(false)
  supportsReg     Boolean @default(false)
  supportsLicense Boolean @default(false)
  customRegex     String?

  // rate limits (per API)
  maxPerMinute    Int?
  maxPerDay       Int?
  cooldownSeconds Int?

  // cost + access
  creditsPerSearch Int     @default(1)
  allowUser        Boolean @default(true)
  allowReseller    Boolean @default(true)
  allowAdmin       Boolean @default(true)

  status Boolean @default(true)

  sampleQuery    String?
  sampleResponse Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceApis ServiceApi[]
}

model ServiceApi {
  id        String  @id @default(cuid())
  serviceId String
  apiId     String
  priority  Int     @default(1) // for future failover ordering
  enabled   Boolean @default(true)

  service Service   @relation(fields: [serviceId], references: [id])
  api     ApiConfig @relation(fields: [apiId], references: [id])

  @@unique([serviceId, apiId])
}

model UserServiceAccess {
  id        String  @id @default(cuid())
  userId    String
  serviceId String
  allowed   Boolean @default(true)

  user    User    @relation(fields: [userId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([userId, serviceId])
}

model SearchHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  serviceId    String?
  service      Service? @relation(fields: [serviceId], references: [id])
  query        String
  detectedType String
  status       String // success|error|blocked
  results      Json?
  cost         Int      @default(0)
  ip           String
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amountPkr Int      @default(0)
  coins     Int      @default(0)
  note      String?
  createdAt DateTime @default(now())
}

model CreditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  delta     Int
  reason    String
  actorId   String?
  actor     User?    @relation("CreditLogActor", fields: [actorId], references: [id])
  createdAt DateTime @default(now())
}

model AccessLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  email     String?
  ip        String
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

model IPList {
  id        String   @id @default(cuid())
  ip        String   @unique
  type      String // BLACKLIST|WHITELIST
  reason    String?
  createdAt DateTime @default(now())
}

model AdminAudit {
  id        String   @id @default(cuid())
  actorId   String
  actor     User     @relation("AdminAuditActor", fields: [actorId], references: [id])
  action    String
  meta      Json?
  ip        String
  createdAt DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  key       String?
  category  String
  title     String
  message   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  meta      Json?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, key])
  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])
}

model SupportTicket {
  id                 String              @id @default(cuid())
  token              String              @unique
  subject            String
  status             SupportTicketStatus @default(OPEN)
  category           String              @default("GENERAL")
  priority           String              @default("NORMAL")
  source             String              @default("dashboard")
  userId             String?
  user               User?               @relation("SupportTicketOwner", fields: [userId], references: [id])
  assignedAdminId    String?
  assignedAdmin      User?               @relation("SupportTicketAssignee", fields: [assignedAdminId], references: [id])
  contactEmail       String?
  contactName        String?
  lastMessageAt      DateTime            @default(now())
  lastMessagePreview String?
  closedAt           DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  messages           SupportMessage[]

  @@index([userId, createdAt])
  @@index([status, updatedAt])
  @@index([token])
}

model SupportMessage {
  id            String               @id @default(cuid())
  ticketId      String
  ticket        SupportTicket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType    SupportMessageSender
  authorId      String?
  author        User?                @relation("SupportMessageAuthor", fields: [authorId], references: [id])
  body          String
  isReadByUser  Boolean              @default(false)
  isReadByAdmin Boolean              @default(false)
  createdAt     DateTime             @default(now())

  @@index([ticketId, createdAt])
  @@index([authorId, createdAt])
}
