PORT=8080
NODE_ENV=development
DATABASE_URL=postgresql://elookup:elookup@localhost:5432/elookup?schema=public
REDIS_URL=redis://localhost:6379

# Performance
SEARCH_CACHE_TTL_SEC=180
SEARCH_CACHE_TTL_CNIC_SEC=300
SEARCH_CACHE_TTL_MOBILE_SEC=180
SEARCH_CACHE_TTL_VEHICLE_REGISTRATION_SEC=300
SEARCH_CACHE_TTL_CHASSIS_SEC=600
SEARCH_CACHE_TTL_ENGINE_SEC=600
SEARCH_CACHE_TTL_GENERAL_SEC=120
SEARCH_MAX_CONCURRENCY=5
SEARCH_API_TIMEOUT_MS=20000
SEARCH_REPEAT_WINDOW_SEC=60
SEARCH_REPEAT_THROTTLE_LIMIT=10

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_API_KEY_SECRET=change_me_api_key
JWT_API_KEY_TTL_SECONDS=31536000
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# Session cookie auth (USER/RESELLER)
SESSION_COOKIE_NAME=elookup.sid
SESSION_REDIS_PREFIX=sess:
SESSION_TTL_SECONDS=43200
SESSION_SECRET=change_me_session

APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173

# OTP Email (use Gmail App Password in production)
MAIL_FROM="Elookup <no-reply@elookup.local>"
# Example (Mailhog/dev):
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

ADMIN_ALERT_EMAIL=admin@elookup.local
CONTACT_TELEGRAM=https://t.me/elookup_support
CONTACT_EMAIL=support@elookup.xyz
